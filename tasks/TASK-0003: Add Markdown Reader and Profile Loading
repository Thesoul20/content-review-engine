import pytest

from content_review_engine.parser.markdown import read_markdown


def test_read_markdown_file(tmp_path):
    file_path = tmp_path / "article.md"
    file_path.write_text("# Title\n\nContent", encoding="utf-8")

    content = read_markdown(file_path)

    assert content == "# Title\n\nContent"


def test_read_markdown_file_with_markdown_extension(tmp_path):
    file_path = tmp_path / "article.markdown"
    file_path.write_text("# Title", encoding="utf-8")

    content = read_markdown(file_path)

    assert content == "# Title"


def test_read_markdown_missing_file_should_fail(tmp_path):
    file_path = tmp_path / "missing.md"

    with pytest.raises(FileNotFoundError):
        read_markdown(file_path)


def test_read_markdown_invalid_extension_should_fail(tmp_path):
    file_path = tmp_path / "article.txt"
    file_path.write_text("Content", encoding="utf-8")

    with pytest.raises(ValueError):
        read_markdown(file_path)
```

