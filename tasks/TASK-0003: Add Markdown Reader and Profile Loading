import pytest
from pydantic import ValidationError

from content_review_engine.config.profiles import load_profile


def test_load_profile_from_yaml(tmp_path):
    file_path = tmp_path / "wechat.yaml"
    file_path.write_text(
        """
name: wechat
target_platform: wechat
tone: clear and professional
max_title_length: 32
max_paragraph_length: 220
""".strip(),
        encoding="utf-8",
    )

    profile = load_profile(file_path)

    assert profile.name == "wechat"
    assert profile.target_platform == "wechat"
    assert profile.max_title_length == 32
    assert profile.max_paragraph_length == 220


def test_load_profile_missing_file_should_fail(tmp_path):
    file_path = tmp_path / "missing.yaml"

    with pytest.raises(FileNotFoundError):
        load_profile(file_path)


def test_load_profile_invalid_extension_should_fail(tmp_path):
    file_path = tmp_path / "profile.txt"
    file_path.write_text("name: wechat", encoding="utf-8")

    with pytest.raises(ValueError):
        load_profile(file_path)


def test_load_profile_empty_file_should_fail(tmp_path):
    file_path = tmp_path / "empty.yaml"
    file_path.write_text("", encoding="utf-8")

    with pytest.raises(ValueError):
        load_profile(file_path)


def test_load_profile_invalid_schema_should_fail(tmp_path):
    file_path = tmp_path / "invalid.yaml"
    file_path.write_text(
        """
name: wechat
""".strip(),
        encoding="utf-8",
    )

    with pytest.raises(ValidationError):
        load_profile(file_path)
```

